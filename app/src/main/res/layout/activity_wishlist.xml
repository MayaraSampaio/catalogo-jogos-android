<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/wishList"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".WishlistActivity"
    android:padding="32dp">

    <TextView
        android:id="@+id/tvTopo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lista de Desejos"
        android:textSize="22sp"
        android:layout_marginTop="10dp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Catálogo (toque para adicionar)"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/listCatalogo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Meus desejados (toque para remover)"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/listDesejos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="8dp" />

</LinearLayout>

